---
// TocFloating.astro — 悬浮文章目录
// 宽屏：固定在内容右侧空白区域
// 窄屏：通过右下角按钮展开底部面板
---

<div id="toc-root" style="display:none">
  <!-- ===== 宽屏侧边栏 ===== -->
  <aside
    id="toc-sidebar"
    class="hidden xl:flex fixed z-40 w-48 flex-col"
    style="top:6rem;right:max(1rem,calc((100vw - 48rem - 2rem)/2 - 12rem - 2rem));max-height:calc(100vh - 8rem)"
  >
    <div
      class="text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-3 shrink-0"
    >
      目录
    </div>
    <nav id="toc-nav-desktop" class="text-sm leading-relaxed overflow-y-auto" style="max-height:50vh"></nav>
  </aside>

  <!-- ===== 窄屏 FAB 按钮 ===== -->
  <button
    id="toc-fab"
    class="xl:hidden fixed end-4 bottom-[7rem] z-40 flex size-10 items-center justify-center rounded-full bg-accent text-accent-foreground shadow-lg transition-opacity hover:opacity-90"
    aria-label="打开目录"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="8" y1="6" x2="21" y2="6" />
      <line x1="8" y1="12" x2="21" y2="12" />
      <line x1="8" y1="18" x2="21" y2="18" />
      <line x1="3" y1="6" x2="3.01" y2="6" />
      <line x1="3" y1="12" x2="3.01" y2="12" />
      <line x1="3" y1="18" x2="3.01" y2="18" />
    </svg>
  </button>

  <!-- ===== 窄屏遮罩 + 底部面板 ===== -->
  <div
    id="toc-overlay"
    class="xl:hidden fixed inset-0 z-40 hidden bg-black/30 backdrop-blur-sm"
  >
    <aside
      id="toc-drawer"
      class="animate-slide-up absolute inset-x-0 bottom-0 max-h-[70vh] overflow-y-auto rounded-t-2xl border-t border-border bg-background p-5 shadow-2xl"
    >
      <div class="mb-4 flex items-center justify-between">
        <span class="text-sm font-semibold text-foreground">目录</span>
        <button
          id="toc-close"
          class="rounded p-1 text-muted-foreground transition-colors hover:text-foreground"
          aria-label="关闭目录"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
      <nav id="toc-nav-mobile" class="text-base leading-relaxed"></nav>
    </aside>
  </div>
</div>

<style is:global>
  @keyframes slide-up {
    from { transform: translateY(100%); }
    to   { transform: translateY(0); }
  }
  .animate-slide-up {
    animation: slide-up 0.25s ease-out;
  }

  /* ---- TOC 容器 ---- */
  #toc-nav-desktop li {
    position: relative;
    padding-left: 0;
  }

  /* TOC 链接 */
  #toc-nav-desktop a {
    display: block;
    border-left: 2px solid transparent;
    padding-left: 0.5rem;
    color: var(--color-muted-foreground);
    transition: border-color 0.15s, color 0.15s;
    word-break: break-word;
    overflow-wrap: break-word;
    white-space: normal;
    line-height: 1.6;
    padding-top: 0.125rem;
    padding-bottom: 0.125rem;
  }

  #toc-nav-desktop a.toc-active {
    border-left-color: var(--color-accent);
    color: var(--color-accent);
  }

  #toc-nav-desktop a:hover {
    color: var(--color-accent);
  }

  /* ---- 目录滚动区无滚动条 ---- */
  #toc-nav-desktop {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #toc-nav-desktop::-webkit-scrollbar {
    display: none;
  }

  #toc-sidebar {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #toc-sidebar::-webkit-scrollbar {
    display: none;
  }
</style>

<script is:inline data-astro-rerun>
  function initToc() {
    const article = document.getElementById("article");
    if (!article) return;

    const headings = article.querySelectorAll("h2, h3");
    if (headings.length < 2) return;

    const root = document.getElementById("toc-root");
    if (root) root.style.display = "";

    // 确保每个标题都有 id
    headings.forEach((h, i) => {
      if (!h.id) {
        h.id =
          h.textContent
            ?.toLowerCase()
            .replace(/[^a-z0-9一-鿿]+/g, "-")
            .replace(/(^-|-$)/g, "") || `heading-${i}`;
      }
    });

    // 构建 TOC HTML
    let tocHtml = '<ul>';
    headings.forEach((h) => {
      const isH3 = h.tagName === "H3";
      const text = h.textContent?.replace(/#$/, "").trim() || "";
      tocHtml += `
        <li class="${isH3 ? "ml-3" : ""}">
          <a href="#${h.id}"
            class="toc-link text-muted-foreground transition-colors hover:text-accent ${isH3 ? "text-xs" : ""}"
            data-heading="${h.id}">
            ${text}
          </a>
        </li>`;
    });
    tocHtml += "</ul>";

    // 填充桌面和移动端的 TOC
    const desktop = document.getElementById("toc-nav-desktop");
    const mobile = document.getElementById("toc-nav-mobile");
    if (desktop) desktop.innerHTML = tocHtml;
    if (mobile) mobile.innerHTML = tocHtml;

    // 目录滚动容器现在是 nav 而不是 aside
    const tocNav = document.getElementById("toc-nav-desktop");
    if (tocNav) {
      tocNav.style.maxHeight = "50vh";
      tocNav.style.overflowY = "auto";
    }

    // IntersectionObserver — 高亮当前标题 + 自动滚动到可见
    const links = desktop?.querySelectorAll(".toc-link") ?? [];
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const linkEl = desktop?.querySelector(
            `.toc-link[data-heading="${entry.target.id}"]`
          );
          if (entry.isIntersecting && linkEl) {
            const link = linkEl;
            // 高亮当前
            links.forEach((l) => {
              l.classList.remove("toc-active", "text-accent");
              l.classList.add("text-muted-foreground");
            });
            link.classList.add("toc-active", "text-accent");
            link.classList.remove("text-muted-foreground");

            // 自动滚动到目录中间
            if (tocNav) {
              const navRect = tocNav.getBoundingClientRect();
              const linkRect = link.getBoundingClientRect();
              const linkCenter = linkRect.top + linkRect.height / 2;
              const navCenter = navRect.top + navRect.height / 2;
              const scrollOffset = linkCenter - navCenter;
              if (Math.abs(scrollOffset) > 20) {
                tocNav.scrollBy({ top: scrollOffset, behavior: "smooth" });
              }
            }
          }
        }
      },
      { rootMargin: "-80px 0px -70% 0px" }
    );
    headings.forEach((h) => observer.observe(h));

    // ===== 窄屏交互 =====
    const fab = document.getElementById("toc-fab");
    const overlay = document.getElementById("toc-overlay");
    const closeBtn = document.getElementById("toc-close");
    const mobileLinks = mobile?.querySelectorAll("a");

    function openToc() {
      if (overlay) {
        overlay.classList.remove("hidden");
        document.body.style.overflow = "hidden";
      }
    }
    function closeToc() {
      if (overlay) {
        overlay.classList.add("hidden");
        document.body.style.overflow = "";
      }
    }

    fab?.addEventListener("click", openToc);
    closeBtn?.addEventListener("click", closeToc);
    overlay?.addEventListener("click", (e) => {
      if (e.target === overlay) closeToc();
    });

    mobileLinks?.forEach((a) => {
      a.addEventListener("click", (e) => {
        handleTocClick(e, a, closeToc);
      });
    });
    desktop?.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", (e) => {
        handleTocClick(e, a);
      });
    });
  }

  function handleTocClick(e, anchor, afterScroll) {
    e.preventDefault();
    const href = anchor.getAttribute("href");
    if (!href?.startsWith("#")) return;
    const targetId = href.slice(1);
    const target = document.getElementById(decodeURIComponent(targetId));
    if (target) {
      target.scrollIntoView({ behavior: "smooth" });
    }
    history.replaceState(null, "", "#" + targetId);
    afterScroll?.();
  }

  /** 拦截文章正文里 markdown 生成的 heading anchor 链接，同样用 replaceState */
  function interceptArticleHeadingLinks() {
    const article = document.getElementById("article");
    if (!article) return;
    article.addEventListener("click", (e) => {
      const anchor = (e.target).closest?.("a");
      if (!anchor) return;
      const href = anchor.getAttribute("href");
      if (!href?.startsWith("#")) return;
      e.preventDefault();
      const targetId = href.slice(1);
      const target = document.getElementById(decodeURIComponent(targetId));
      if (target) target.scrollIntoView({ behavior: "smooth" });
      history.replaceState(null, "", href);
    });
  }
  interceptArticleHeadingLinks();

  initToc();
</script>
