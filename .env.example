# Supabase 配置（用于文章点赞功能）
# 不填则点赞按钮自动隐藏，不影响博客正常使用

# Supabase 项目 URL，在 Supabase Dashboard → Settings → API → Project URL
# 格式：https://<project-id>.supabase.co
PUBLIC_SUPABASE_URL=https://abc123def456.supabase.co

# Supabase 匿名密钥，在 Supabase Dashboard → Settings → API → Project API keys → anon/public
# 格式：以 eyJ 开头的 JWT token，后面跟着一长串 base64
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFiYzEyM2RlZjQ1NiIsInJvbGUiOiJhbm9uIiwiaWF0IjoxNjAwMDAwMDAwLCJleHAiOjE5MTU2NzY4MDB9.example

# Google 站点验证
PUBLIC_GOOGLE_SITE_VERIFICATION=
